generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  MASTER
  ADMIN
}

enum WorkshopStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum ApplicationStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportTargetType {
  WORKSHOP
  PHOTO
  REVIEW
  SERVICE_CALL
}

enum ReportStatus {
  NEW
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum ModerationEntityType {
  USER
  WORKSHOP
  PHOTO
  REVIEW
  REPORT
}

enum ModerationAction {
  APPROVED
  REJECTED
  BLOCKED
  UPDATED
  VERIFIED
  UNVERIFIED
  RESOLVED
  DELETED
}

model User {
  id                   String           @id @default(uuid()) @db.Uuid
  fullName             String
  phone                String           @unique
  email                String?          @unique
  passwordHash         String
  role                 UserRole         @default(CLIENT)
  isBlocked            Boolean          @default(false)
  isVerifiedMaster     Boolean          @default(false)
  /// Master-only opt-in: when true, this master may receive urgent
  /// "service call" pushes (Yandex-Taxi-style on-demand requests).
  /// Default is false — master must explicitly enable in settings.
  isMasterOnline       Boolean          @default(false)
  /// Admin marker — true when this user is part of the Closed Testing
  /// programme on Google Play and we want to track their daily activity
  /// so the admin gets a Telegram report of who isn't opening the app.
  isTester             Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  workshops            Workshop[]       @relation("WorkshopOwner")
  favorites            Favorite[]
  reviews              Review[]         @relation("ReviewAuthor")
  customerApplications Application[]    @relation("CustomerApplications")
  uploadedPhotos       WorkshopPhoto[]  @relation("PhotoUploader")
  reports              Report[]         @relation("ReportReporter")
  moderationLogs       ModerationLog[]  @relation("ModerationActor")
  deviceTokens         DeviceToken[]
  analyticsEvents      AnalyticsEvent[]
  clientCalls          ServiceCall[]    @relation("ServiceCallClient")
  assignedCalls        ServiceCall[]    @relation("ServiceCallAssignedMaster")
}

enum DevicePlatform {
  IOS
  ANDROID
}

model DeviceToken {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  /// Expo push token, e.g. "ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]"
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String             @id @default(uuid()) @db.Uuid
  name        String             @unique
  slug        String             @unique
  description String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workshops   WorkshopCategory[]
  services    WorkshopService[]
}

model Workshop {
  id              String             @id @default(uuid()) @db.Uuid
  ownerId         String             @db.Uuid
  title           String
  description     String
  phone           String
  telegram        String?
  addressLine     String
  city            String
  latitude        Decimal?           @db.Decimal(9, 6)
  longitude       Decimal?           @db.Decimal(9, 6)
  openingHours    String?
  status          WorkshopStatus     @default(PENDING)
  averageRating   Decimal            @default(0) @db.Decimal(3, 2)
  reviewsCount    Int                @default(0)
  favoritesCount  Int                @default(0)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  owner           User               @relation("WorkshopOwner", fields: [ownerId], references: [id])
  categories      WorkshopCategory[]
  services        WorkshopService[]
  photos          WorkshopPhoto[]
  reviews         Review[]
  applications    Application[]
  favorites       Favorite[]

  @@index([status, city])
  @@index([ownerId])
}

model WorkshopCategory {
  workshopId String   @db.Uuid
  categoryId String   @db.Uuid
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([workshopId, categoryId])
}

model WorkshopService {
  id          String    @id @default(uuid()) @db.Uuid
  workshopId  String    @db.Uuid
  categoryId  String?   @db.Uuid
  name        String
  description String?
  priceFrom   Decimal?  @db.Decimal(12, 2)
  priceTo     Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])

  @@index([workshopId])
}

model WorkshopPhoto {
  id         String      @id @default(uuid()) @db.Uuid
  workshopId String      @db.Uuid
  uploaderId String      @db.Uuid
  key        String      @unique
  url        String
  status     PhotoStatus @default(PENDING)
  isPrimary  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  workshop   Workshop    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  uploader   User        @relation("PhotoUploader", fields: [uploaderId], references: [id])

  @@index([workshopId, status])
}

model Review {
  id         String       @id @default(uuid()) @db.Uuid
  authorId   String       @db.Uuid
  workshopId String       @db.Uuid
  rating     Int
  comment    String
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  author     User         @relation("ReviewAuthor", fields: [authorId], references: [id])
  workshop   Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([authorId, workshopId])
  @@index([workshopId, status])
}

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  workshopId String   @db.Uuid
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([userId, workshopId])
  @@index([workshopId])
}

model Application {
  id               String            @id @default(uuid()) @db.Uuid
  workshopId       String            @db.Uuid
  customerId       String            @db.Uuid
  customerName     String
  customerPhone    String
  carModel         String?
  issueDescription String
  preferredDate    DateTime?
  status           ApplicationStatus @default(NEW)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workshop         Workshop          @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  customer         User              @relation("CustomerApplications", fields: [customerId], references: [id])

  @@index([customerId])
  @@index([workshopId, status])
}

model Report {
  id         String           @id @default(uuid()) @db.Uuid
  reporterId String?          @db.Uuid
  targetType ReportTargetType
  targetId   String           @db.Uuid
  reason     String
  comment    String?
  status     ReportStatus     @default(NEW)
  resolution String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  reporter   User?            @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

model ModerationLog {
  id         String               @id @default(uuid()) @db.Uuid
  actorId    String?              @db.Uuid
  entityType ModerationEntityType
  entityId   String               @db.Uuid
  action     ModerationAction
  fromStatus String?
  toStatus   String?
  note       String?
  metadata   Json?
  createdAt  DateTime             @default(now())
  actor      User?                @relation("ModerationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

enum ServiceCallStatus {
  /// Dispatcher is offering the call to candidate masters in turn.
  SEARCHING
  /// A master accepted; client now has master's contact and is waiting for arrival.
  ASSIGNED
  /// Client marked the job as done.
  COMPLETED
  /// Client cancelled while still SEARCHING (or after ASSIGNED if master was no-show).
  CANCELLED
  /// Every candidate either rejected or timed out — nobody available right now.
  NO_MASTERS
}

/// On-demand "call a master" request. Unlike Application (which targets one
/// specific workshop), a ServiceCall is broadcast in-turn to nearby masters
/// matching the chosen category. The dispatcher (cron) walks
/// `candidateMasterIds` from index 0 upward — pushing each master a 30s
/// notification window. First master to accept gets the job.
model ServiceCall {
  id          String  @id @default(uuid()) @db.Uuid
  clientId    String  @db.Uuid
  categoryId  String  @db.Uuid
  /// Coordinates the client picked on the map (where the master should come).
  lat         Float
  lng         Float
  address     String?
  /// Phone the master will call (defaults to client's profile phone, but the
  /// client can edit it on the call screen — e.g. to leave a partner's number).
  clientPhone String
  description String?

  status ServiceCallStatus @default(SEARCHING)

  /// Sorted list of candidate master ids (closest first). Persisted as an
  /// array because the dispatcher cron rotates through it across restarts.
  candidateMasterIds  String[]  @db.Uuid
  /// Pointer into candidateMasterIds. The current "ringing" master is at
  /// `candidateMasterIds[currentCandidateIdx]` until they accept, reject,
  /// or `currentExpiresAt` passes.
  currentCandidateIdx Int       @default(0)
  /// When the current candidate's 30s window expires. Cron polls and
  /// advances the index when this slips into the past.
  currentExpiresAt    DateTime?

  assignedMasterId String?   @db.Uuid
  assignedAt       DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  client         User  @relation("ServiceCallClient", fields: [clientId], references: [id], onDelete: Cascade)
  assignedMaster User? @relation("ServiceCallAssignedMaster", fields: [assignedMasterId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([assignedMasterId, status])
  @@index([status, currentExpiresAt])
}

/// Lightweight product-analytics log. Mobile / admin POST events here;
/// queries are SQL-based (Prisma Studio or direct psql), no third-party
/// analytics provider. `properties` stores arbitrary per-event payload
/// (e.g. workshopId for workshop_viewed). `userId` is null for events
/// before sign-in (app_opened, signup_started). Server records the
/// client IP and user agent for sanity (catch bots, segment by region).
model AnalyticsEvent {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  name       String
  properties Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId])
  @@index([createdAt])
}
