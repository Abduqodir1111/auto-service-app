{
  "name": "@stomvp/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run build -w @stomvp/shared && prisma generate",
    "dev": "nest start --watch",
    "prebuild": "npm run build -w @stomvp/shared && prisma generate",
    "build": "nest build",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:db:up": "docker compose -f test/docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f test/docker-compose.test.yml down -v",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^5.2.0",
    "@prisma/client": "^6.1.0",
    "@sentry/nestjs": "^10.51.0",
    "@stomvp/shared": "*",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.16",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "prisma": "^6.1.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
