{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "isolatedModules": true }]
  },
  "setupFiles": ["<rootDir>/test/setup-env.ts"],
  "globalSetup": "<rootDir>/test/global-setup.ts",
  "testTimeout": 30000,
  "verbose": true,
  "maxWorkers": 1
}
