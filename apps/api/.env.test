# Test-only env. Used by jest e2e suite.
# Brought up by `npm run test:db:up` (postgres on 5435, redis on 6382).
# DEVSMS_API_TOKEN intentionally NOT set — in NODE_ENV=test the SMS service
# falls back to console.log instead of sending real SMS, and the review
# bypass phone (+998900000099 / 00000) lets us exercise the full register
# flow without any token.

NODE_ENV=test
PORT=3199
APP_URL=http://localhost:3199
WEB_URL=http://localhost:5173
MOBILE_DEEP_LINK=mastertop://

DATABASE_URL=postgresql://test:test@localhost:5435/stomvp_test?schema=public
REDIS_URL=redis://localhost:6382

JWT_SECRET=test-jwt-secret-must-be-at-least-16-chars-long-for-zod
JWT_EXPIRES_IN=1h

S3_BUCKET=stomvp-media-test
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_PUBLIC_URL=http://localhost:9000/stomvp-media-test
S3_FORCE_PATH_STYLE=true

SMS_SERVICE_NAME=MasterTopTest
SMS_OTP_TTL_SECONDS=300
SMS_OTP_RESEND_SECONDS=1
SMS_OTP_MAX_ATTEMPTS=5
