{
  "name": "@stomvp/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "predev": "npm run build -w @stomvp/shared",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "npm run build -w @stomvp/shared",
    "build": "npm run build:ios",
    "build:ios": "expo export --platform ios",
    "build:android": "expo export --platform android",
    "bundle:android": "cd android && ./gradlew bundleRelease",
    "assemble:android": "cd android && ./gradlew assembleRelease",
    "eas-build-post-install": "cd ../.. && npm run build -w @stomvp/shared"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@sentry/react-native": "^6.22.0",
    "@stomvp/shared": "*",
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.7.9",
    "expo": "~52.0.49",
    "expo-application": "~6.0.2",
    "expo-av": "~15.0.2",
    "expo-device": "~7.0.3",
    "expo-haptics": "~14.0.1",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.21",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-webview": "13.12.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.7.2"
  }
}
