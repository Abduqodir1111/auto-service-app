{
  "expo": {
    "name": "STOMVP",
    "slug": "stomvp",
    "scheme": "stomvp",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#F4EFE7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.stomvp"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "STOMVP определяет вашу геопозицию, чтобы показать ближайшие объявления на карте."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
